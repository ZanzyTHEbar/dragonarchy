{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "default_agent": "plan",
  // Performance & UX
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "build/**"]
  },
  "lsp": true,
  "autoupdate": false,
  "experimental": {
    "disable_paste_summary": true
  },
  "instructions": [
    "./AGENTS.md",
    "./rules/general/memory-bank.mdc",
    "./rules/general/task-authority-boundaries.mdc"
  ],
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/sse",
      "enabled": true
    },
    "jira_rovo": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false,
      "timeout": 20000
    },
    "actualbudget": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/actualbudget/mcp",
      "oauth": {
        "scope": "mcp:actualbudget"
      },
      "enabled": true
    },
    "mealie": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/mealie/mcp",
      "oauth": {
        "scope": "mcp:mealie"
      },
      "enabled": true
    },
    "memory-kg": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/memory/mcp",
      "oauth": {
        "scope": "mcp:memory"
      },
      "enabled": true,
      "timeout": 20000
    },
    "allpepper-memory-bank": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/allpepper-memory-bank/mcp",
      "oauth": {
        "scope": "mcp:allpepper-memory-bank"
      },
      "enabled": true,
      "timeout": 20000
    },
    "saga": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/saga/mcp",
      "oauth": {
        "scope": "mcp:saga"
      },
      "enabled": true,
      "timeout": 20000
    },
    "penpot": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/penpot/mcp",
      "oauth": {
        "scope": "mcp:penpot"
      },
      "enabled": true,
      "timeout": 20000
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@beta",
    "opencode-rules@latest"
  ]
}
