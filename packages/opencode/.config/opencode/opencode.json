{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "default_agent": "plan",
  // Performance & UX
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "build/**"]
  },
  "lsp": true,
  "autoupdate": true,
  "experimental": {
	"disable_paste_summary": true,
	"chat": { "messages": { "transform": true } }
  },
  "instructions": [
    "./rules/general/memory-bank.mdc",
    "./rules/general/task-authority-boundaries.mdc"
  ],
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/sse",
      "enabled": true
    },
    "jira_rovo": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false,
      "timeout": 20000
    },
    "actualbudget": {
      "type": "remote",
      "url": "http://192.168.0.157:3000/http",
      "enabled": false
    },
    "mealie": {
      "type": "remote",
      "url": "http://192.168.0.157:3031/mcp",
      "enabled": false
    },
    "allpepper-memory-bank": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@allpepper/memory-bank-mcp"
      ],
      "environment": {
        "MEMORY_BANK_ROOT": "{env:MEMORY_BANK_ROOT}"
      },
      "enabled": true,
      "timeout": 20000
    },
    "saga": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "saga-mcp"
      ],
      "environment": {
        "DB_PATH": "{env:HOME}/.local/share/opencode/saga-tasks.db"
      },
      "enabled": true,
      "timeout": 20000
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@beta",
    "opencode-rules@latest"
  ]
}
