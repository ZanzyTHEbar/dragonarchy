{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-luna#xhigh",
  "default_agent": "plan",
  //"model_tiers": {
  //  "quick":   { "model": "xai/grok-4.5#high" },
  //  "standard": { "model": "openai/gpt-5.6-luna#xhigh" },
  //  "advanced": { "model": "openai/gpt-5.6-sol#xhigh" }
  //},
  "agent": {
    "explore": {
      "model": "openai/gpt-5.6-luna"
    },
    "general": {
      "model": "openai/gpt-5.6-luna"
    }
  },
  "provider": {
    "opencode-go": {
      "options": {
        "baseURL": "http://127.0.0.1:17321/v1",
        "headers": {
          "sleeve-harness": "opencode",
          "sleeve-provider": "opencode"
        }
      },
      "models": {
        "gpt-5.6-sol": {
          "name": "GPT-5.6 Sol via Sleev",
          "tool_call": true,
          "reasoning": true,
          "limit": {
            "context": 272000,
            "output": 65536
          }
        }
      }
    }
  },
  // Performance & UX
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "build/**"]
  },
  "lsp": true,
  "autoupdate": false,
  "experimental": {
    "disable_paste_summary": true
  },
  "instructions": [
    "./AGENTS.md",
    "./rules/general/memory-bank.mdc",
    "./rules/general/code-search.mdc",
    "./rules/general/task-authority-boundaries.mdc",
    "./rules/cursor-team-kit/no-inline-imports.mdc",
    "./rules/cursor-team-kit/typescript-exhaustive-switch.mdc"
  ],
  "mcp": {
   "jira_rovo": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false,
      "timeout": 20000
    },
    "actualbudget": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/actualbudget/mcp",
      "oauth": {
        "scope": "mcp:actualbudget"
      },
      "enabled": false
    },
    "mealie": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/mealie/mcp",
      "oauth": {
        "scope": "mcp:mealie"
      },
      "enabled": false
    },
    "memory-kg": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/memory/mcp",
      "oauth": {
        "scope": "mcp:memory"
      },
      "enabled": false,
      "timeout": 20000
    },
    "allpepper-memory-bank": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/allpepper-memory-bank/mcp",
      "oauth": {
        "scope": "mcp:allpepper-memory-bank"
      },
      "enabled": true,
      "timeout": 20000
    },
    "saga": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/saga/mcp",
      "oauth": {
        "scope": "mcp:saga"
      },
      "enabled": true,
      "timeout": 20000
    },
    "penpot": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/penpot/mcp",
      "oauth": {
        "scope": "mcp:penpot"
      },
      "enabled": false,
      "timeout": 20000
    },
    "codebase-memory": {
      "type": "local",
      "command": ["sh", "-c", "exec \"$HOME/.local/bin/codebase-memory-mcp\""],
      "enabled": true,
      "timeout": 300000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@0.0.75"],
      "enabled": true,
      "timeout": 20000
    },
    "browser-use": {
      "type": "local",
      "command": ["uvx", "--from", "browser-use[cli]", "browser-use", "--mcp"],
      "enabled": true,
      "timeout": 60000
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@beta",
    "opencode-rules@latest",
    "/home/daofficialwizard/.local/share/opencode/ponytail/.opencode/plugins/ponytail.mjs"
  ],
  "skills": {
    "paths": [
      "/home/daofficialwizard/.local/share/opencode/ponytail/skills"
    ]
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "external_directory": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "repo_clone": "allow",
    "repo_overview": "allow",
    "lsp": "allow",
    "skill": "allow"
  }
}
