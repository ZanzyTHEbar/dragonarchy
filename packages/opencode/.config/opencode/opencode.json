{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "default_agent": "plan",
  // Performance & UX
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "build/**"]
  },
  "lsp": true,
  "autoupdate": false,
  "experimental": {
    "disable_paste_summary": true
  },
  "instructions": [
    "./AGENTS.md",
    "./rules/general/memory-bank.mdc",
    "./rules/general/code-search.mdc",
    "./rules/general/task-authority-boundaries.mdc",
    "./rules/cursor-team-kit/no-inline-imports.mdc",
    "./rules/cursor-team-kit/typescript-exhaustive-switch.mdc"
  ],
  "mcp": {
   "jira_rovo": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "timeout": 20000
    },
    //dev"actualbudget": {
    //  "type": "remote",
    //  "url": "https://mcp.zacariahheim.com/actualbudget/mcp",
    //  "oauth": {
    //    "scope": "mcp:actualbudget"
    //  }
    //},
    //"mealie": {
    //  "type": "remote",
    //  "url": "https://mcp.zacariahheim.com/mealie/mcp",
    //  "oauth": {
    //    "scope": "mcp:mealie"
    //  }
    //},
    //"memory-kg": {
    //  "type": "remote",
    //  "url": "https://mcp.zacariahheim.com/memory/mcp",
    //  "oauth": {
    //    "scope": "mcp:memory"
    //  },
    //  "timeout": 20000
    //},
    "allpepper-memory-bank": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/allpepper-memory-bank/mcp",
      "oauth": {
        "scope": "mcp:allpepper-memory-bank"
      },
      "timeout": 20000
    },
    "saga": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/saga/mcp",
      "oauth": {
        "scope": "mcp:saga"
      },
      "timeout": 20000
    },
    "penpot": {
      "type": "remote",
      "url": "https://mcp.zacariahheim.com/penpot/mcp",
      "oauth": {
        "scope": "mcp:penpot"
      },
      "timeout": 20000
    },
    "codebase-memory": {
      "type": "local",
      "command": ["sh", "-c", "exec \"$HOME/.local/bin/codebase-memory-mcp\""],
      "enabled": true,
      "timeout": 300000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@0.0.75"],
      "timeout": 20000
    },
    "browser-use": {
      "type": "local",
      "command": ["uvx", "--from", "browser-use[cli]", "browser-use", "--mcp"],
      "timeout": 60000
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@beta",
    "opencode-rules@latest",
    "/home/daofficialwizard/.local/share/opencode/ponytail/.opencode/plugins/ponytail.mjs"
  ],
  "skills": {
    "paths": [
      "/home/daofficialwizard/.local/share/opencode/ponytail/skills"
    ]
  },
  "permission": {
   "lsp": "allow"
  }
}
