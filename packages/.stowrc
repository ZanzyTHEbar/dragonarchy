--ignore=\.package$
--ignore=^README\.md$
--ignore=^README\.txt$
--ignore=^README$
--ignore=^\.git$
--ignore=^\.gitignore$
--ignore=^\.gitmodules$
--ignore=^\.vscode$
--ignore=^\.idea$
--ignore=.*~$
--ignore=^\#.*\#$
--ignore=^\.#.*$
--ignore=.*\.bak$
--ignore=.*\.backup$
--ignore=.*\.swp$
--ignore=.*\.swo$
--ignore=^\.config/zsh/autosuggest-theme\.zsh$
#
# Runtime-managed theme "current" links:
# These are created/updated by theme scripts and should not be stowed.
--ignore=\\.config/btop/themes/current\\.theme$
--ignore=\\.config/walker/themes/current/style\\.css$
--ignore=\\.config/kitty/colors\\.conf$
--ignore=\\.config/gtk-3\\.0/(gtk\\.css|settings\\.ini)$
--ignore=\\.config/gtk-4\\.0/(gtk\\.css|settings\\.ini)$
--ignore=\\.config/hypr/config/keyboard\\.local\\.conf$
--ignore=\\.config/hypr/config/monitor\\.local\\.conf$
--ignore=\\.config/swaync/style\\.css$
--ignore=\\.config/clipse/theme\\.toml$
--ignore=\\.config/wlogout/wlogout\\.css$

# Systemd wants symlinks (created by systemd when enabling units, should not be stowed)
--ignore=\\.config/systemd/user/.*\\.target\\.wants/.*$

# Never stow a user-level hicolor theme definition; it overrides /usr/share/icons/hicolor/index.theme
# and can break scalable/symbolic icon lookup across GTK apps (Waybar tray, Walker, notifications).
--ignore=\\.local/share/icons/hicolor/index\\.theme$
