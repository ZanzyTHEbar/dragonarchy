// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.4",
      "enable_thinking": false,
      "effort": "high"
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5.4",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "base_keymap": "VSCode",
  "sticky_scroll": {
    "enabled": true,
  },
  "gutter": {
    "line_numbers": true,
  },
  "file_types": {
    "json": ["*.json.liquid"],
    "markdown": ["*.md.liquid", "*.rmd"],
    "yaml": ["*.yaml.liquid"],
    "liquid-javascript": ["*.js.liquid"],
    "liquid-css": ["*.css.liquid"],
    "rmd": ["*.Rmd"],
    "liquid-scss": ["*.scss.liquid"],
  },
  "colorize_brackets": true,
  "auto_indent_on_paste": true,
  "linked_edits": true,
  "show_edit_predictions": true,
  "agent_servers": {
    },
  "vim_mode": true,
  "session": {
    "trust_all_worktrees": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "ui_font_family": "CaskaydiaMono Nerd Font",
  "buffer_font_family": "CaskaydiaMono Nerd Font",
  "terminal": {
    "cursor_shape": "underline",
    "env": {},
    "font_family": "CaskaydiaMono Nerd Font",
  },
  "theme": {
    "mode": "dark",
    "light": "Nord Light",
    "dark": "Nord Dark",
  },
}
