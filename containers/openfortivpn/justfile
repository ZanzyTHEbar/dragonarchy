# OpenFortiVPN Container - justfile

set shell := ["bash", "-cu"]

image_name := "ghcr.io/daofficialwizard/openfortivpn"
tag := "latest"

# Build everything
build: build-webui build-go build-image

# Generate web UI (go:generate)
generate:
    @echo "Running go generate..."
    cd control-plane && go generate ./cmd/server/...

# Build web UI
build-webui:
    @echo "Building web UI..."
    bash scripts/build-webui.sh

# Build Go control plane
build-go:
    @echo "Building Go control plane..."
    cd control-plane && go build -o openfortivpn-control-plane ./cmd/server
    cd control-plane && go build -o openfortivpn-cli ./cmd/cli

# Build container image
build-image:
    @echo "Building container image..."
    podman build -t {{image_name}}:{{tag}} .

# Build multi-arch image
build-multi:
    @echo "Building multi-arch image..."
    cd control-plane && GOOS=linux GOARCH=amd64 go build -o openfortivpn-control-plane ./cmd/server
    podman build --platform linux/amd64 -t {{image_name}}:{{tag}}-amd64 .
    cd control-plane && GOOS=linux GOARCH=arm64 go build -o openfortivpn-control-plane ./cmd/server
    podman build --platform linux/arm64 -t {{image_name}}:{{tag}}-arm64 .

# Push image to registry
push:
    podman push {{image_name}}:{{tag}}

# Run tests
test:
    cd control-plane && go test -v ./...

# Clean build artifacts
clean:
    rm -f control-plane/openfortivpn-control-plane
    rm -f control-plane/openfortivpn-cli
    rm -rf webui/dist
    rm -rf webui/node_modules

# Install CLI to ~/.local/bin
install-cli:
    mkdir -p $HOME/.local/bin
    cp control-plane/openfortivpn-cli $HOME/.local/bin/vpnctl
    chmod +x $HOME/.local/bin/vpnctl
    @echo "Installed vpnctl to ~/.local/bin"

# Start the stack
dev-up:
    docker compose up -d

# Stop the stack
dev-down:
    docker compose down

# View logs
logs:
    docker compose logs -f

# Format Go code
fmt:
    cd control-plane && go fmt ./...

# Run linter
lint:
    cd control-plane && go vet ./...
    @if command -v staticcheck >/dev/null 2>&1; then \
        cd control-plane && staticcheck ./...; \
    else \
        echo "staticcheck not installed, skipping"; \
    fi
